# --- Ruvali backend (Express + MySQL) — Hostinger / VPS ---
# Copy to .env on the server. Do not commit .env.

# Server
PORT=5005
NODE_ENV=production

# Public URL where this API + /uploads are reachable (no trailing slash).
# Set on Hostinger so JSON can expose fullImageUrl for images.
PUBLIC_BASE_URL=https://ruvali.co.in

MAX_UPLOAD_SIZE_MB=5

# MySQL
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_POOL_SIZE=10

# Auth (must change in production)
ADMIN_JWT_SECRET=
ADMIN_JWT_EXPIRES_IN=7d
CUSTOMER_JWT_SECRET=
CUSTOMER_JWT_EXPIRES_IN=30d

# CORS — comma-separated origins (include your CRA site URL)
CORS_ORIGINS=https://YOUR_FRONTEND_DOMAIN.example,http://localhost:3000

# WhatsApp optional (heavy; persist .wwebjs_auth only on persistent disk outside git)
WHATSAPP_ENABLED=false

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM_NAME=Ruvali Store
ADMIN_NOTIFICATION_EMAIL=
